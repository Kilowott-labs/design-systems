{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "agent-theme/agntix-parallax-image",
  "version": "1.0.0",
  "title": "Agntix Parallax Image",
  "category": "kw",
  "icon": "format-image",
  "description": "Full-width image section with GSAP scroll-linked parallax effect. Image moves at a slower rate than the page scroll, creating depth.",
  "textdomain": "agent-theme",
  "attributes": {
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "sectionHeight": {
      "type": "number",
      "default": 800
    },
    "sectionHeightMobile": {
      "type": "number",
      "default": 400
    },
    "parallaxAmount": {
      "type": "number",
      "default": 0.3
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": { "margin": true }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}
