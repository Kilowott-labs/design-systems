{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kw-package/cta",
  "version": "1.0.0",
  "title": "CTA Section",
  "category": "ytf",
  "icon": "megaphone",
  "description": "Call-to-action section with 5 style variants: full-width banner, split with image, inline gradient card, newsletter signup, and CTA with testimonial.",
  "textdomain": "kw-package",
  "attributes": {
    "style": {
      "type": "string",
      "default": "banner",
      "enum": ["banner", "split", "card", "newsletter", "testimonial"]
    },
    "colorMode": {
      "type": "string",
      "default": "dark",
      "enum": ["light", "dark"]
    },
    "heading": {
      "type": "string",
      "default": "Ready to transform your workflow?"
    },
    "description": {
      "type": "string",
      "default": "Join 10,000+ teams already shipping faster. Start your free trial today — no credit card required."
    },
    "showDescription": {
      "type": "boolean",
      "default": true
    },
    "primaryButtonText": {
      "type": "string",
      "default": "Start Free Trial"
    },
    "primaryButtonUrl": {
      "type": "string",
      "default": "#"
    },
    "showPrimaryArrow": {
      "type": "boolean",
      "default": true
    },
    "secondaryButtonText": {
      "type": "string",
      "default": "Talk to Sales"
    },
    "secondaryButtonUrl": {
      "type": "string",
      "default": "#"
    },
    "showSecondaryButton": {
      "type": "boolean",
      "default": true
    },
    "imageUrl": {
      "type": "string",
      "default": "https://images.unsplash.com/photo-1758876021840-0209f3bd38f4?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzUxMTAzOTN8&ixlib=rb-4.1.0&q=80&w=1080"
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageAlt": {
      "type": "string",
      "default": "Creative studio workspace with design materials"
    },
    "newsletterPlaceholder": {
      "type": "string",
      "default": "Enter your email"
    },
    "newsletterButtonText": {
      "type": "string",
      "default": "Subscribe"
    },
    "newsletterPrivacyText": {
      "type": "string",
      "default": "We respect your privacy. Unsubscribe at any time."
    },
    "testimonialQuote": {
      "type": "string",
      "default": "We evaluated 12 tools before choosing FlowStack. Six months later, our team velocity is up 3x and our engineers are happier than ever."
    },
    "testimonialAuthor": {
      "type": "string",
      "default": "David Park, CTO"
    },
    "testimonialCompany": {
      "type": "string",
      "default": "Runway ML \u00b7 Series C"
    },
    "testimonialAvatarUrl": {
      "type": "string",
      "default": "https://images.unsplash.com/photo-1643285740368-f7f1ba6b116f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzUxMTA0NDN8&ixlib=rb-4.1.0&q=80&w=1080"
    },
    "testimonialAvatarId": {
      "type": "number",
      "default": 0
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}
