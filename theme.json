        }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "em", "%", "vw"],
      "spacingSizes": [
        { "slug": "xs", "size": "0.5rem", "name": "XS" },
        { "slug": "s", "size": "1rem", "name": "S" },
        { "slug": "m", "size": "1.5rem", "name": "M" },
        { "slug": "l", "size": "3rem", "name": "L" },
        { "slug": "xl", "size": "5rem", "name": "XL" }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--dm-sans)",
      "lineHeight": "1.5"
    },
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--grey-dark)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "800",
          "letterSpacing": "-0.02em",
          "lineHeight": "1.15"
        },
        "color": {
          "text": "var(--wp--preset--color--teal)"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h2)",
          "fontWeight": "700",
          "letterSpacing": "-0.02em",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h3)",
          "fontWeight": "600",
          "letterSpacing": "-0.02em"
        }
      },
      "p": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--body)",
          "lineHeight": "1.6"
        }
      },
      "a": {
        "color": {
          "text": "var(--wp--preset--color--teal)"
        },
        "typography": {
          "fontWeight": "600"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "4px"
        },
        "typography": {
          "fontWeight": "600"
        }
      },
      "core/group": {
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--m)",
            "bottom": "var(--wp--preset--spacing--m)"
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "header-transparent",
